# Normalize line endings to LF in the repo; check out as-is on Windows
* text=auto eol=lf
*.py text eol=lf
*.csv text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf

# Binaries — no line-ending conversion
*.xlsx binary
*.kmz binary
*.png binary
*.jpg binary
